# --- 2FAS Vault environment variables ---
# All variables MUST use the APP2FAS_ prefix.

# HTTP port (default 3000)
APP2FAS_PORT=3000

# Required: API key validated by every /api/* route via constant-time XOR compare.
# Use a long, random value (>= 32 chars). Anyone with this key can read/modify
# the backup, so keep it server-side only.
APP2FAS_API_SECRET=change-me-use-a-long-random-string

# Required: base64-encoded Firebase service-account JSON.
# The decoded JSON MUST contain at least these fields:
#   - project_id
#   - databaseURL          (e.g. https://<project>-default-rtdb.firebaseio.com)
#   - client_email
#   - private_key
# To produce the value:
#   base64 -w 0 path/to/serviceAccountKey.json
APP2FAS_FIREBASE_CREDENTIALS_B64=

# Optional: if set to 1 AND no Firebase credentials are provided, the server
# uses an in-memory backup store. Useful for local UI work without Firebase.
# DO NOT enable this in production.
# APP2FAS_ALLOW_MEMORY_FALLBACK=1

# Optional: standard Node toggle — set NODE_ENV=production to mute error
# bodies in 5xx responses (only `{ "error": "Internal server error." }` is
# returned to clients).
# NODE_ENV=production
